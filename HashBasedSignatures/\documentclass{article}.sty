\documentclass{article}
\usepackage{tikz}
\usepackage[margin=0.8in]{geometry}
\usetikzlibrary{positioning}

\definecolor{myblue}{rgb}{0.5,0,1}

\newcommand{\drawtree}[4]{
  \begin{scope}[shift={(#1, #2)}]
    \node at (2,3.5) {$R_{#3}$};

    % Level 2
    \foreach \x in {0,2,4,6} {
      \node[circle,draw,fill=white] (l2\x) at (\x,0) {};
    }

    % Level 1
    \foreach \x/\l/\r in {1/0/2, 5/4/6} {
      \node[circle,draw,fill=white] (l1\x) at (\x,1) {};
      \draw (l1\x) -- (l2\l);
      \draw (l1\x) -- (l2\r);
    }

    % Level 0
    \node[circle,draw,fill=white] (root) at (3,2) {};
    \draw (root) -- (l1 1);
    \draw (root) -- (l1 5);

    % Leaves
    \foreach \x in {0,1,2,3,4,5,6,7} {
      \node[draw,fill=white,minimum size=5mm] (leaf\x) at (\x,-1.2) {};
    }

    % Connect leaves to level 2
    \foreach \x/\l/\r in {0/0/1,2/2/3,4/4/5,6/6/7} {
      \draw (l2\x) -- (leaf\l);
      \draw (l2\x) -- (leaf\r);
    }

    % Highlighted path
    \foreach \n in {#4} {
      \pgfmathtruncatemacro{\len}{stringlength("#4")}
      \foreach \i in {0,...,31} {
        \pgfmathsetmacro{\c}{int(mod(\i+1,10))}
        \ifnum\i<\len
          \pgfmathsetmacro{\char}{int(substr("#4", \i, \i+1))}
          \ifcase\char
          \or
            \ifnum\i=0
              \fill[myblue] (root) circle[radius=0.2];
            \fi
            \ifnum\i=1
              \fill[myblue] (l1 1) circle[radius=0.2];
              \fill[myblue] (l1 5) circle[radius=0.2];
            \fi
            \ifnum\i=2
              \fill[myblue] (l2 4) circle[radius=0.2];
            \fi
          \fi
        \fi
      }
    }

    % Text below
    \node at (3,-1.8) {\texttt{#4}};
    \node at (3,-2.3) {sk$_#3$};
  \end{scope}
}

\begin{document}
\begin{center}
\begin{tikzpicture}[scale=1]

% Draw each tree
\drawtree{0}{0}{4}{100}
\drawtree{5.5}{0}{3}{011}
\drawtree{11}{0}{3}{011}

\drawtree{0}{-5}{5}{101}
\drawtree{5.5}{-5}{7}{111}
\drawtree{11}{-5}{0}{000}

\end{tikzpicture}
\end{center}
\end{document}
